# ===== SUPABASE CONFIG =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# ===== SERVER CONFIG =====
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ===== ENCRYPTION KEYS =====
ENCRYPTION_MASTER_KEY=your_32_byte_hex_key_here
JWT_SECRET=your_32_byte_jwt_secret_here
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=your_32_byte_refresh_secret_here

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=logs/app.log
