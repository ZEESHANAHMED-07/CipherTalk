# ─────────────────────────────────────────────
#  CipherTalk — .gitignore
#  Covers: Node.js, Vite/React, Express, Supabase
# ─────────────────────────────────────────────


# ── Secrets & Environment Variables ─────────────────────────────────────────
.env
.env.*
!.env.example          # allow the example template to be committed
.env.local
.env.development.local
.env.test.local
.env.production.local


# ── Node dependencies ────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz


# ── Build output ─────────────────────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
backend/dist/
build/


# ── Vite cache ───────────────────────────────────────────────────────────────
frontend/.vite/
.vite/


# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/


# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini


# ── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # share recommended extensions
!.vscode/settings.json     # share workspace settings if desired
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.bak
*.tmp


# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo


# ── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/


# ── Misc ─────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
.cache/
